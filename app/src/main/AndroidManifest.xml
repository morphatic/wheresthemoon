<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Exact alarms flip the "void" line at the right minute.
         SCHEDULE_EXACT_ALARM covers Android 12/12L; USE_EXACT_ALARM is
         granted automatically on 13+ (fine for a sideloaded personal app;
         Play restricts it to alarm/calendar apps). -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name">

        <receiver
            android:name=".WTMAppWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/wtmapp_widget_info" />
        </receiver>

        <!-- The two lock-screen tiles. Samsung One UI grants lock widgets
             ~123x54dp, two side by side under the clock; the
             widgetStyle=complication meta-data is Samsung's marker for
             lock-screen widgets, ignored elsewhere. -->
        <receiver
            android:name=".WTMAspectComplication"
            android:exported="false"
            android:label="@string/aspect_tile_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/wtm_aspect_info" />
            <meta-data
                android:name="widgetStyle"
                android:value="complication" />
        </receiver>

        <receiver
            android:name=".WTMIngressComplication"
            android:exported="false"
            android:label="@string/ingress_tile_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/wtm_ingress_info" />
            <meta-data
                android:name="widgetStyle"
                android:value="complication" />
        </receiver>

        <service
            android:name=".WTMDream"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>
    </application>

</manifest>
